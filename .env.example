# Copy this file to `.env.local` and fill in real values there.
# Never commit `.env.local` or any file containing real secrets.

# Public production URL of the deployed site (no trailing slash).
# Used for metadata, canonical URLs, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL=

# Public contact details shown on the site (Footer, /legal, /contact). Leave
# empty until confirmed — the site never displays a placeholder value
# publicly.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# PAY.JP public key. Must use the NEXT_PUBLIC_ prefix — Next.js only inlines
# NEXT_PUBLIC_-prefixed variables into the browser bundle. Safe to expose to
# the browser; it is designed for client-side tokenization only.
NEXT_PUBLIC_PAYJP_PUBLIC_KEY=

# PAY.JP secret key. Server-side only. Must NEVER be prefixed with
# NEXT_PUBLIC_ and must never be referenced from a client component.
PAYJP_SECRET_KEY=

# PAY.JP webhook verification token (Dashboard → Webhook settings). PAY.JP
# sends this same value back in the `X-Payjp-Webhook-Token` header of every
# webhook request; src/app/api/webhooks/payjp/route.ts rejects any request
# whose header doesn't match. Server-side only. There is currently no
# database, so the webhook route only verifies and acknowledges requests —
# see the TODOs in that file before relying on it for anything beyond that.
PAYJP_WEBHOOK_SECRET=

# Endpoint the contact form forwards each valid submission to. Required for
# the contact form to report success — there is no database, so a submission
# is only ever considered handled once this endpoint accepts it.
# Server-side only.
CONTACT_FORM_ENDPOINT=
