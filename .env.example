# Copy this file to `.env.local` and fill in real values there.
# Never commit `.env.local` or any file containing real secrets.

# Public production URL of the deployed site (no trailing slash).
# Used for metadata, canonical URLs, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL=

# Public contact details shown on the site (Footer, /legal). Leave empty
# until confirmed — the site never displays a placeholder value publicly.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# PAY.JP public key. Safe to expose to the browser (it is designed for
# client-side tokenization only) — but only add it once real PAY.JP
# integration is implemented.
PAYJP_PUBLIC_KEY=

# PAY.JP secret key. Server-side only. Must NEVER be prefixed with
# NEXT_PUBLIC_ and must never be referenced from a client component.
PAYJP_SECRET_KEY=

# Endpoint (or provider config) the contact form submits to once a real
# backend is connected. Currently unused — the contact form only validates
# and keeps data in local component state.
CONTACT_FORM_ENDPOINT=
